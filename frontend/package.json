  },
  "dependencies": {
    "next": "15.5.18",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^3",
    "postcss": "^8",
    "autoprefixer": "^10"
  },
  "packageManager": "yarn@1.22.22"
